# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sso_platform

# JWT Configuration
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256
JWT_ISSUER=urn:unsia:sso
JWT_AUDIENCE=sso-platform

# Token Expiration (in seconds)
ACCESS_TOKEN_EXPIRY=3600
REFRESH_TOKEN_EXPIRY=2592000
ID_TOKEN_EXPIRY=3600
AUTHORIZATION_CODE_EXPIRY=600

# Redis Configuration (for session storage)
REDIS_URL=redis://host:6379
REDIS_PASSWORD=

# Session Configuration
SESSION_SECRET=super-secret-session-key-sso-platform-2026
SESSION_MAX_AGE=86400

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://host:3000
NEXT_PUBLIC_API_URL=http://host:3000/api

# Security
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Admin Configuration
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=admin-password-123
SUPERADMIN_PASSWORD=superadmin-password-123

# CORS Configuration
ALLOWED_ORIGINS=http://host:3000,http://host:3001

# Logging
LOG_LEVEL=info
