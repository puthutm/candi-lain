# =====================================================
# SSO Platform - Environment Configuration Template
# =====================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local with real secrets to git

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
DATABASE_URL=postgresql://user:password@localhost:5432/sso_db

# =====================================================
# APPLICATION URLS & ENDPOINTS
# =====================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# =====================================================
# AUTHENTICATION & SECURITY
# =====================================================
# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-nextauth-key-change-in-production

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=urn:unsia:sso
JWT_AUDIENCE=urn:unsia:platform

# Token Expiry Times (in seconds)
ACCESS_TOKEN_EXPIRY=3600           # 1 hour
REFRESH_TOKEN_EXPIRY=2592000       # 30 days
ID_TOKEN_EXPIRY=3600               # 1 hour
AUTHORIZATION_CODE_EXPIRY=600      # 10 minutes
SESSION_MAX_AGE=86400              # 24 hours
PASSWORD_RESET_TOKEN_EXPIRY=3600   # 1 hour
EMAIL_VERIFICATION_TOKEN_EXPIRY=86400  # 24 hours

# Cryptography
BCRYPT_ROUNDS=12
SALT_ROUNDS=10
CRYPTO_ALGORITHM=aes-256-cbc

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_EXPIRE_DAYS=90
PASSWORD_HISTORY_COUNT=5

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000        # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
MAX_LOGIN_ATTEMPTS=5
LOGIN_WINDOW_MS=900000             # 15 minutes

# Default/Security Passwords (for initial setup only)
DEFAULT_PASSWORD=Change@Me!123
DEFAULT_RESET_PASSWORD=Reset@Me!123
DEFAULT_APPLICANT_PASSWORD=Welcome@2026!

# PKCE Configuration
PKCE_ENABLED=true

# =====================================================
# INSTITUTION CONFIGURATION
# =====================================================
INSTITUTION_NAME=Universitas Siber Asia
INSTITUTION_SHORT_NAME=UNSIA
INSTITUTION_ACRONYM=UNSIA
INSTITUTION_DOMAIN=unsia.ac.id
INSTITUTION_WEBSITE=https://unsia.ac.id
INSTITUTION_EMAIL_DOMAIN=@unsia.ac.id
INSTITUTION_PHONE=+62-XXX-XXXX
INSTITUTION_ADDRESS=Jakarta, Indonesia

# Contact Information
SUPPORT_EMAIL=support@unsia.ac.id
ADMIN_EMAIL=admin@unsia.ac.id

# Storage & Media
STORAGE_BASE_URL=http://storage.unsia.ac.id
CDN_URL=http://storage.unsia.ac.id

# Branding
LOGO_URL=http://storage.unsia.ac.id/logo.png
FAVICON_URL=http://storage.unsia.ac.id/favicon.ico
PRIMARY_COLOR=#003366
SECONDARY_COLOR=#006699

# =====================================================
# OAUTH2 & CLIENT CONFIGURATION
# =====================================================
# Default OAuth2 Client Settings
OAUTH2_DEFAULT_GRANT_TYPES=authorization_code,refresh_token

# =====================================================
# CACHE & SESSION CONFIGURATION
# =====================================================
# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Session Configuration
SESSION_SECRET=your-session-secret-key-change-in-production
SESSION_TIMEOUT=86400  # seconds (24 hours)

# =====================================================
# INTERSERVICE COMMUNICATION
# =====================================================
# SIAKAD Integration
SIAKAD_BASE_URL=http://localhost:3003
SIAKAD_CALLBACK_URL=http://localhost:3003/api/auth/callback
SIAKAD_WEBHOOK_URL=http://localhost:3003/api/webhooks/sso
SIAKAD_CLIENT_ID=siakad-platform
SIAKAD_CLIENT_SECRET=siakad-platform-client-secret-key-2026

# LMS Integration
LMS_BASE_URL=http://localhost:3004
LMS_CALLBACK_URL=http://localhost:3004/api/auth/callback
LMS_WEBHOOK_URL=http://localhost:3004/api/webhooks/sso
LMS_CLIENT_ID=lms-platform
LMS_CLIENT_SECRET=lms-platform-client-secret-key-2026

# PMB Integration
PMB_BASE_URL=http://localhost:3002
PMB_CALLBACK_URL=http://localhost:3002/api/auth/callback
PMB_WEBHOOK_URL=http://localhost:3002/api/webhooks/sso
PMB_CLIENT_ID=pmb-platform
PMB_CLIENT_SECRET=pmb-platform-client-secret-key-2026

# Keuangan Integration
KEUANGAN_BASE_URL=http://localhost:3005
KEUANGAN_CALLBACK_URL=http://localhost:3005/api/auth/callback
KEUANGAN_WEBHOOK_URL=http://localhost:3005/api/webhooks/sso
KEUANGAN_CLIENT_ID=keuangan-platform
KEUANGAN_CLIENT_SECRET=keuangan-platform-client-secret-key-2026

# HRIS Integration
HRIS_BASE_URL=http://localhost:3006
HRIS_CALLBACK_URL=http://localhost:3006/api/auth/callback
HRIS_WEBHOOK_URL=http://localhost:3006/api/webhooks/sso
HRIS_CLIENT_ID=hris-platform
HRIS_CLIENT_SECRET=hris-platform-client-secret-key-2026

# Bank Konten Integration
BANK_KONTEN_BASE_URL=http://localhost:3007
BANK_KONTEN_CALLBACK_URL=http://localhost:3007/api/auth/callback
BANK_KONTEN_WEBHOOK_URL=http://localhost:3007/api/webhooks/sso
BANK_KONTEN_CLIENT_ID=bank-konten-platform
BANK_KONTEN_CLIENT_SECRET=bank-konten-platform-client-secret-key-2026

# =====================================================
# EMAIL CONFIGURATION
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=no-reply@unsia.ac.id
SMTP_FROM_NAME=UNSIA SSO

# =====================================================
# LOGGING & MONITORING
# =====================================================
LOG_LEVEL=info
ENABLE_AUDIT_LOGGING=true
ENABLE_SECURITY_LOGGING=true

# =====================================================
# DEVELOPMENT & DEBUGGING
# =====================================================
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
DEBUG=*  # Uncomment to enable debug logs

# =====================================================
# SEED CONFIGURATION (Development Only)
# =====================================================
# Set these to dynamically override individual callback domains based on subdomains
# SEED_DOMAIN_BASE=dev-unsia.id
# SEED_DOMAIN_PROTOCOL=https

# Initial OAuth2 clients to seed during database initialization
SEED_SIAKAD_CLIENT_ID=siakad-platform
SEED_SIAKAD_CLIENT_SECRET=siakad-platform-client-secret-key-2026
SEED_SIAKAD_CALLBACK_URL=http://localhost:3003/api/auth/callback

SEED_LMS_CLIENT_ID=lms-platform
SEED_LMS_CLIENT_SECRET=lms-platform-client-secret-key-2026
SEED_LMS_CALLBACK_URL=http://localhost:3004/api/auth/callback

SEED_PMB_CLIENT_ID=pmb-platform
SEED_PMB_CLIENT_SECRET=pmb-platform-client-secret-key-2026
SEED_PMB_CALLBACK_URL=http://localhost:3002/api/auth/callback

SEED_KEUANGAN_CLIENT_ID=keuangan-platform
SEED_KEUANGAN_CLIENT_SECRET=keuangan-platform-client-secret-key-2026
SEED_KEUANGAN_CALLBACK_URL=http://localhost:3005/api/auth/callback

SEED_HRIS_CLIENT_ID=hris-platform
SEED_HRIS_CLIENT_SECRET=hris-platform-client-secret-key-2026
SEED_HRIS_CALLBACK_URL=http://localhost:3006/api/auth/callback

SEED_BANK_KONTEN_CLIENT_ID=bank-konten-platform
SEED_BANK_KONTEN_CLIENT_SECRET=bank-konten-platform-client-secret-key-2026
SEED_BANK_KONTEN_CALLBACK_URL=http://localhost:3007/api/auth/callback
