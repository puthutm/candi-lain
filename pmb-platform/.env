# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sso_platform

# Redis Configuration
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3002/api

# SSO Platform OAuth2 Configuration for Staff Authentication
SSO_OAUTH_CLIENT_ID=pmb-platform
SSO_OAUTH_CLIENT_SECRET=pmb-platform-client-secret-key-2026
SSO_OAUTH_AUTHORIZE_URL=http://localhost:3000/oauth/authorize
SSO_OAUTH_TOKEN_URL=http://localhost:3000/oauth/token
SSO_OAUTH_USERINFO_URL=http://localhost:3000/oauth/userinfo
SSO_OAUTH_CALLBACK_URL=http://localhost:3002/api/auth/callback/unsia-sso
NEXT_PUBLIC_SSO_OAUTH_AUTHORIZE_URL=http://localhost:3000/oauth/authorize
NEXT_PUBLIC_SSO_OAUTH_CALLBACK_URL=http://localhost:3002/api/auth/callback/unsia-sso

# NextAuth Configuration
NEXTAUTH_SECRET=super-secret-nextauth-key-pmb-platform-2026
AUTH_URL=http://localhost:3002
AUTH_TRUST_HOST=true

