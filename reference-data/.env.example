# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sso_platform

# Redis Configuration (for session verification from SSO Core)
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=

# Session Configuration
SESSION_SECRET=super-secret-session-key-sso-platform-2026
SESSION_MAX_AGE=86400

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# SSO Platform Configuration
NEXT_PUBLIC_SSO_APP_URL=http://localhost:3000

# Admin Configuration
SUPER_ADMIN_EMAIL=admin@example.com
